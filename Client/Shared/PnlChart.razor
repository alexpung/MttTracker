@if (Points is null || Points.Count == 0)
{
    <p class="text-muted mb-0">No data yet — add a tournament to see your profit curve.</p>
}
else
{
    <div class="pnl-chart-wrap" @onmouseleave="ClearHover">
        <svg viewBox="0 0 @Width @Height" class="pnl-chart" preserveAspectRatio="none" role="img" aria-label="Cumulative profit and loss over time">
            <!-- zero line -->
            <line x1="@Pad" y1="@Y(0).ToString(Inv)" x2="@(Width - Pad)" y2="@Y(0).ToString(Inv)"
                  stroke="#adb5bd" stroke-width="1" stroke-dasharray="4 4" />

            <!-- area under the curve -->
            <polygon points="@AreaPoints" fill="@(IsProfit ? "rgba(25,135,84,0.15)" : "rgba(220,53,69,0.15)")" />

            <!-- profit line -->
            <polyline points="@LinePoints" fill="none"
                      stroke="@(IsProfit ? "#198754" : "#dc3545")" stroke-width="2"
                      stroke-linejoin="round" stroke-linecap="round" />

            @if (hoverIndex is int hi)
            {
                <line x1="@X(hi).ToString(Inv)" y1="0" x2="@X(hi).ToString(Inv)" y2="@Height"
                      stroke="#6c757d" stroke-width="1" stroke-dasharray="3 3" />
                <circle cx="@X(hi).ToString(Inv)" cy="@Y(Points[hi].Cumulative).ToString(Inv)" r="4"
                        fill="@(Points[hi].Cumulative >= 0 ? "#198754" : "#dc3545")" stroke="white" stroke-width="1.5" />
            }

            <!-- invisible hit zones, one per point, for hover detection -->
            @for (var i = 0; i < Points.Count; i++)
            {
                var idx = i;
                var left = idx == 0 ? 0 : (X(idx - 1) + X(idx)) / 2;
                var right = idx == Points.Count - 1 ? Width : (X(idx) + X(idx + 1)) / 2;
                <rect x="@left.ToString(Inv)" y="0" width="@((right - left).ToString(Inv))" height="@Height"
                      fill="transparent" @onmouseenter="() => hoverIndex = idx" />
            }
        </svg>

        @if (hoverIndex is int h)
        {
            var point = Points[h];
            <div class="pnl-tooltip" style="left:@((X(h) / Width * 100).ToString(Inv))%; top:@((Y(point.Cumulative) / Height * 100).ToString(Inv))%;">
                <div class="pnl-tooltip-date">@point.Date.ToString("d MMM yyyy")</div>
                <div class="pnl-tooltip-location">@point.Location</div>
                <div>Tournament: <span class="@Format.SignClass(point.Profit)">@Format.Money(point.Profit)</span></div>
                <div>Running total: <span class="@Format.SignClass(point.Cumulative)">@Format.Money(point.Cumulative)</span></div>
            </div>
        }
    </div>
    <div class="d-flex justify-content-between text-muted small mt-1">
        <span>@Points[0].Date.ToString("MMM yyyy")</span>
        <span>@Points[^1].Date.ToString("MMM yyyy")</span>
    </div>
}

@code {
    [Parameter] public IReadOnlyList<PnlPoint>? Points { get; set; }

    private int? hoverIndex;

    private const int Width = 800;
    private const int Height = 280;
    private const int Pad = 30;
    private static readonly System.Globalization.CultureInfo Inv = System.Globalization.CultureInfo.InvariantCulture;

    // Computed once per Points change (OnParametersSet) rather than re-scanning
    // the whole list on every Y() call, which is invoked once per point.
    private decimal scaleMin;
    private decimal scaleMax;

    private bool IsProfit => Points![^1].Cumulative >= 0;

    protected override void OnParametersSet()
    {
        if (Points is { Count: > 0 })
        {
            scaleMin = Math.Min(Points.Min(p => p.Cumulative), 0m);
            scaleMax = Math.Max(Points.Max(p => p.Cumulative), 0m);
        }
    }

    private void ClearHover() => hoverIndex = null;

    private double X(int index)
    {
        if (Points!.Count == 1) return Width / 2.0;
        return Pad + (double)index / (Points!.Count - 1) * (Width - 2 * Pad);
    }

    private double Y(decimal value)
    {
        var range = scaleMax - scaleMin;
        if (range == 0) return Height / 2.0;
        var t = (double)((value - scaleMin) / range);
        return Height - Pad - t * (Height - 2 * Pad);
    }

    private string LinePoints =>
        string.Join(" ", Points!.Select((p, i) => $"{X(i).ToString(Inv)},{Y(p.Cumulative).ToString(Inv)}"));

    private string AreaPoints
    {
        get
        {
            var baseY = Y(0).ToString(Inv);
            var first = X(0).ToString(Inv);
            var last = X(Points!.Count - 1).ToString(Inv);
            return $"{first},{baseY} {LinePoints} {last},{baseY}";
        }
    }
}
